# AWS (DynamoDB)
# Copy to .env.local and fill in your values. Never commit .env.local.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
DYNAMODB_TABLE_NAME=btc-guesser

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_secret_min_32_chars

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# E2E tests (Playwright) – optional; for authenticated specs only
E2E_TEST_USER_EMAIL=
E2E_TEST_USER_PASSWORD=

# Binance klines proxy (Lambda) – optional; set in prod when Binance blocks Vercel IPs. Same URL for local and Vercel keeps behavior in sync.
BINANCE_KLINES_PROXY_URL=
# BINANCE_PROXY_API_KEY=   # optional; only if you secured the Lambda route with an authorizer
